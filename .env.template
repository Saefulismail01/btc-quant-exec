# ============================================================================
# BTC-QUANT v4.4 — Environment Configuration
# ============================================================================
# IMPORTANT: Never commit .env to git! Use .env.template as reference only.

# ============================================================================
# LLM & External Services
# ============================================================================
MOONSHOT_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
LLM_PROVIDER=auto

# ============================================================================
# Telegram Bot Config
# ============================================================================

# Option A: Signal/Metrics Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Option B: Dedicated Execution Telegram Bot (RECOMMENDED for live trading)
# If empty, execution layer falls back to TELEGRAM_BOT_TOKEN above
EXECUTION_TELEGRAM_BOT_TOKEN=
EXECUTION_TELEGRAM_CHAT_ID=

# ============================================================================
# EXECUTION LAYER — Binance Testnet Credentials
# ============================================================================
# Get from: https://testnet.binancefuture.com
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET=

# ============================================================================
# EXECUTION LAYER — Binance Mainnet Credentials
# ============================================================================
# Only populate AFTER testnet validation! Keep empty by default!
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_SECRET=

# ============================================================================
# EXECUTION LAYER — Lighter.xyz Testnet Credentials
# ============================================================================
# Get from: Lighter.xyz testnet dashboard → Account Settings → API Keys
LIGHTER_TESTNET_API_KEY=
LIGHTER_TESTNET_API_SECRET=
LIGHTER_API_KEY_INDEX=

# ============================================================================
# EXECUTION LAYER — Lighter.xyz Mainnet Credentials
# ============================================================================
# Only populate AFTER testnet validation!
LIGHTER_MAINNET_API_KEY=
LIGHTER_MAINNET_API_SECRET=

# ============================================================================
# EXECUTION LAYER — Mode & Safety Flags
# ============================================================================
# Execution Gateway: binance | lighter
EXECUTION_GATEWAY=binance

# Mode: testnet | mainnet (or live)
EXECUTION_MODE=testnet

# CRITICAL SAFETY FLAG — Must be explicitly set to true to enable trading
# Default: false (trading disabled even if other configs are set)
TRADING_ENABLED=false

# Lighter-specific mode
LIGHTER_EXECUTION_MODE=testnet
LIGHTER_TRADING_ENABLED=false

# ============================================================================
# HTTP Proxy (optional, for Docker environments)
# ============================================================================
HTTP_PROXY=
HTTPS_PROXY=
