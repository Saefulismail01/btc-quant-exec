# ============================================================
# BTC-QUANT v4.4 — Lighter.xyz Execution Layer Configuration
# ============================================================
# Copy this file to backend/.env and fill in your credentials
# CRITICAL: Never commit actual credentials to Git!

# ========== Lighter Execution Mode & Safety ==========
# Mode: testnet or mainnet (DEFAULT: testnet)
LIGHTER_EXECUTION_MODE=testnet

# Safety flag: set to true ONLY when ready to trade (DEFAULT: false)
LIGHTER_TRADING_ENABLED=false

# API Key index (0-254, but 0-1 reserved for official apps) (DEFAULT: 2)
LIGHTER_API_KEY_INDEX=2

# ========== Lighter Testnet Credentials ==========
# Get testnet API credentials from Lighter testnet dashboard
# NEVER hardcode or commit these!
LIGHTER_TESTNET_API_KEY=your_testnet_api_key_here
LIGHTER_TESTNET_API_SECRET=your_testnet_api_secret_here

# Testnet URLs (pre-configured, change only if Lighter updates them)
LIGHTER_TESTNET_BASE_URL=https://testnet.zklighter.elliot.ai
LIGHTER_TESTNET_WS_URL=wss://testnet.zklighter.elliot.ai/stream

# ========== Lighter Mainnet Credentials ==========
# ONLY fill these when you're ready for production trading!
# Leave empty for safety (empty = mainnet disabled)
LIGHTER_MAINNET_API_KEY=
LIGHTER_MAINNET_API_SECRET=

# Mainnet URLs (do not change unless Lighter updates them)
LIGHTER_MAINNET_BASE_URL=https://mainnet.zklighter.elliot.ai
LIGHTER_MAINNET_WS_URL=wss://mainnet.zklighter.elliot.ai/stream

# ========== Signal & Notification Config ==========
# Telegram notification (optional, shared with signal engine)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dedicated execution Telegram (recommended for live trading)
EXECUTION_TELEGRAM_BOT_TOKEN=
EXECUTION_TELEGRAM_CHAT_ID=

# ========== Logging ==========
# Log level: DEBUG, INFO, WARNING, ERROR (DEFAULT: INFO)
LOG_LEVEL=INFO

# ========== Database (usually inherited from backend) ==========
# DB_PATH defaults to backend/app/infrastructure/database/btc-quant.db
# Change only if you want a different location
# DB_PATH=

# ========== Proxy (optional) ==========
# Use if you need HTTP/HTTPS proxies to reach Lighter
# HTTP_PROXY=
# HTTPS_PROXY=
