# ============================================================================
# BTC-QUANT v4.4 — Environment Configuration (Minimal for Lighter Trading)
# ============================================================================

# ============================================================================
# Telegram Bot Config
# ============================================================================

# Option A: Existing Telegram Bot (untuk signal/metrics)
#TELEGRAM_BOT_TOKEN=your_bot_token_here
#TELEGRAM_CHAT_ID=your_chat_id_here

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here


# Option B: Dedicated Execution Telegram Bot (RECOMMENDED for live trading)
# If empty, execution layer falls back to TELEGRAM_BOT_TOKEN above
#EXECUTION_TELEGRAM_BOT_TOKEN=your_bot_token_here
#EXECUTION_TELEGRAM_CHAT_ID=your_chat_id_here
EXECUTION_TELEGRAM_BOT_TOKEN=your_bot_token_here
EXECUTION_TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================================================
# EXECUTION LAYER — Lighter.xyz Testnet Credentials
# ============================================================================
# Get from: Lighter.xyz testnet dashboard → Account Settings → API Keys
LIGHTER_TESTNET_API_KEY=your_testnet_api_key_here
LIGHTER_TESTNET_API_SECRET=your_testnet_api_secret_here

# ============================================================================
# EXECUTION LAYER — Lighter.xyz Mainnet Credentials
# ============================================================================
# Only populate AFTER testnet validation!
LIGHTER_MAINNET_API_KEY=your_mainnet_api_key_here
LIGHTER_MAINNET_API_SECRET=your_mainnet_api_secret_here
LIGHTER_API_KEY_INDEX=3
LIGHTER_ACCOUNT_INDEX=your_account_index_here

# ============================================================================
# EXECUTION LAYER — Mode & Safety Flags
# ============================================================================
# Execution Gateway: binance | lighter
EXECUTION_GATEWAY=lighter

# Mode: testnet | mainnet (or live)
EXECUTION_MODE=mainnet

# [DEPRECATED] This flag is not used by Lighter execution layer
# Use LIGHTER_TRADING_ENABLED above instead
# TRADING_ENABLED=false

# Lighter-specific mode
LIGHTER_EXECUTION_MODE=mainnet
LIGHTER_TRADING_ENABLED=true

# ============================================================================
# Risk Management Config (FixedStrategy v4.4) - CRITICAL for position sizing
# ============================================================================
LIGHTER_LEVERAGE=5
LIGHTER_MARGIN_USD=100.0
LIGHTER_SL_PCT=1.333
LIGHTER_TP_PCT=0.71
