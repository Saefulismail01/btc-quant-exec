      "source": [
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "# Set up the plot\n",
        "fig, ax = plt.subplots(figsize=(7, 7))\n",
        "ax.set_xlim(0, 60)\n",
        "ax.set_ylim(0, 60)\n",
        "ax.set_xlabel('Romeo Arrives (minutes after 8:00 AM)')\n",
        "ax.set_ylabel('Juliet Arrives (minutes after 8:00 AM)')\n",
        "ax.set_title('Probability of Romeo and Juliet Meeting')\n",
        "\n",
        "# The square representing the sample space\n",
        "square = plt.Rectangle((0, 0), 60, 60, fill=None, edgecolor='black', linewidth=1)\n",
        "ax.add_patch(square)\n",
        "\n",
        "# Points to define the meeting region\n",
        "x = np.linspace(0, 60, 100)\n",
        "y1 = np.minimum(x + 15, 60)\n",
        "y2 = np.maximum(x - 15, 0)\n",
        "\n",
        "# Shading the meeting region\n",
        "ax.fill_between(x, y1, y2, color='skyblue', alpha=0.5, label='Meeting Region (|x-y| <= 15)')\n",
        "\n",
        "# Shading the \"no meeting\" regions\n",
        "ax.fill_between(x, y1, 60, color='salmon', alpha=0.2, label='No Meeting')\n",
        "ax.fill_between(x, 0, y2, color='salmon', alpha=0.2)\n",
        "\n",
        "ax.grid(True, linestyle='--', alpha=0.6)\n",
        "ax.legend()\n",
        "plt.show()"
